{
  "version": 8,
  "name": "Field boundaries by confidence (2024)",
  "metadata": {
    "portolan:legend": {
      "title": "Confidence (0–100)",
      "unit": "%",
      "type": "ramp"
    },
    "description": "PRUE field-boundary predictions (2024) colored by modeled confidence (red = low, green = high). Confidence is the raw confidence_mean attribute rescaled to 0–100 using 0.578178 as 100%. Default view filters to confidence >= ~69 (raw 0.4), the recommended-default reliability cutoff."
  },
  "sources": {
    "data": {
      "type": "vector",
      "url": "pmtiles://../alpha/2024_with_confidence.pmtiles"
    }
  },
  "layers": [
    {
      "id": "fields-legend",
      "type": "fill",
      "source": "data",
      "source-layer": "2024",
      "paint": {
        "fill-color": [
          "step",
          ["*", 100, ["/", ["to-number", ["get", "confidence_mean"]], 0.578178]],
          "#d7191c",
          70, "#fec379",
          80, "#f3fabb",
          90, "#cfecb0",
          100, "#33a02c"
        ],
        "fill-opacity": 0
      }
    },
    {
      "id": "fields-fill",
      "type": "fill",
      "source": "data",
      "source-layer": "2024",
      "filter": ["all", ["has", "confidence_mean"], [">=", ["to-number", ["get", "confidence_mean"]], 0.4]],
      "paint": {
        "fill-color": [
          "interpolate", ["linear"],
          ["*", 100, ["/", ["to-number", ["get", "confidence_mean"]], 0.578178]],
          0, "#d7191c",
          70, "#fec379",
          80, "#f3fabb",
          90, "#cfecb0",
          100, "#33a02c"
        ],
        "fill-opacity": 0.5
      }
    },
    {
      "id": "fields-outline",
      "type": "line",
      "source": "data",
      "source-layer": "2024",
      "filter": ["all", ["has", "confidence_mean"], [">=", ["to-number", ["get", "confidence_mean"]], 0.4]],
      "paint": {
        "line-color": [
          "interpolate", ["linear"],
          ["*", 100, ["/", ["to-number", ["get", "confidence_mean"]], 0.578178]],
          0, "#d7191c",
          70, "#fec379",
          80, "#f3fabb",
          90, "#cfecb0",
          100, "#33a02c"
        ],
        "line-width": 1
      }
    }
  ]
}
