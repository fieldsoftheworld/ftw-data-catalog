          [
            "linear"
          ],
          [
            "*",
            100,
            [
              "/",
              [
                "to-number",
                [
                  "get",
                  "confidence_mean"
                ]
              ],
              0.578178
            ]
          ],
          0,
          "#d7191c",
          70,
          "#fec379",
          80,
          "#f3fabb",
