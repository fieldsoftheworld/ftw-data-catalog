{
  "version": 8,
  "name": "Field boundaries by confidence (2025)",
  "metadata": {
    "portolan:legend": {
      "title": "Confidence (0\u2013100)",
      "unit": "%",
      "type": "ramp",
      "stops": [
        {
          "value": 0,
          "color": "#d7191c",
          "label": "0"
        },
        {
          "value": 70,
          "color": "#fec379",
          "label": "70"
        },
        {
          "value": 80,
          "color": "#f3fabb",
          "label": "80"
        },
        {
          "value": 90,
          "color": "#cfecb0",
          "label": "90"
        },
        {
          "value": 100,
          "color": "#33a02c",
          "label": "100"
        }
      ]
    },
    "description": "PRUE 2025 field-boundary predictions colored by modeled confidence (red = low, green = high). Each field is shaded by its confidence_mean attribute, rescaled to 0\u2013100 using 0.578178 as 100%."
  },
  "sources": {
    "data": {
      "type": "vector",
      "url": "pmtiles://https://data.source.coop/ftw/global-field-boundaries/pmtiles/ftw-global-fields-2025.pmtiles"
    }
  },
  "layers": [
    {
      "id": "fields-fill",
