              0.578178
            ]
          ],
          0,
          "#d7191c",
          70,
          "#fec379",
          80,
          "#f3fabb",
          90,
          "#cfecb0",
          100,
          "#33a02c"
        ],
        "fill-opacity": 0.5
      }
    },
    {
      "id": "fields-outline",
      "type": "line",
      "source": "data",
      "source-layer": "fields",
      "paint": {
        "line-color": [
